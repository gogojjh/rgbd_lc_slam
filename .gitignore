# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# ---- Editors ----
.vscode/
.idea/

# ---- Local data & results (keep repo small) ----
data/**
results/**
outputs/**
logs/**

# allow small placeholders
!data/.gitkeep
!results/.gitkeep
!outputs/.gitkeep
!logs/.gitkeep

# misc large artifacts
*.zip
*.png
*.pdf
*.mp4
